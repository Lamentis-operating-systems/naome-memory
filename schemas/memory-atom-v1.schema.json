{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lamentis-operating-systems/naome-memory/raw/main/schemas/memory-atom-v1.schema.json",
  "title": "NAOME Memory Atom Body v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "scope",
    "interval",
    "trigger",
    "seal_reason",
    "goal",
    "plan",
    "internal_state_before",
    "internal_state_after",
    "observations",
    "interpretations",
    "beliefs",
    "decisions",
    "rejected_alternatives",
    "actions",
    "outcome",
    "feedback",
    "formation_signals",
    "topic_keys",
    "entity_ids",
    "outcome_class",
    "goal_key",
    "provenance",
    "relations",
    "artifacts",
    "retention_permission",
    "payload"
  ],
  "properties": {
    "contract_version": { "const": "atom-v1" },
    "scope": { "$ref": "#/$defs/scope" },
    "interval": { "$ref": "#/$defs/interval" },
    "trigger": { "$ref": "#/$defs/text" },
    "seal_reason": {
      "enum": ["goal_completed", "terminal_failure", "goal_changed", "context_changed", "checkpoint", "handoff", "timeout"]
    },
    "goal": { "$ref": "#/$defs/nullableText" },
    "plan": { "type": "array", "items": { "$ref": "#/$defs/text" } },
    "internal_state_before": { "$ref": "#/$defs/stringMap" },
    "internal_state_after": { "$ref": "#/$defs/stringMap" },
    "observations": { "type": "array", "items": { "$ref": "#/$defs/observation" } },
    "interpretations": { "type": "array", "items": { "$ref": "#/$defs/interpretation" } },
    "beliefs": { "type": "array", "items": { "$ref": "#/$defs/belief" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "rejected_alternatives": { "type": "array", "items": { "$ref": "#/$defs/rejectedAlternative" } },
    "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
    "outcome": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/outcome" }] },
    "feedback": { "type": "array", "items": { "$ref": "#/$defs/feedback" } },
    "formation_signals": { "$ref": "#/$defs/formationSignals" },
    "topic_keys": { "$ref": "#/$defs/stringSet" },
    "entity_ids": { "$ref": "#/$defs/stringSet" },
    "outcome_class": { "$ref": "#/$defs/nullableText" },
    "goal_key": { "$ref": "#/$defs/nullableText" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "retention_permission": { "enum": ["transient_only", "semantic_allowed", "semantic_and_exact_allowed"] },
    "payload": { "$ref": "#/$defs/payload" }
  },
  "$defs": {
    "u64": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
    "u32": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
    "ppm": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "text": { "type": "string" },
    "nullableText": { "type": ["string", "null"] },
    "stringSet": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "x-naome-canonical-order": "raw-utf8-ascending"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "x-naome-canonical-order": "raw-utf8-key-ascending"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memory_space_id", "repository_id", "task_id", "agent_id", "session_id"],
      "properties": {
        "memory_space_id": { "$ref": "#/$defs/text" },
        "repository_id": { "$ref": "#/$defs/nullableText" },
        "task_id": { "$ref": "#/$defs/nullableText" },
        "agent_id": { "$ref": "#/$defs/nullableText" },
        "session_id": { "$ref": "#/$defs/text" }
      }
    },
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at_us", "ended_at_us", "recorded_at_us"],
      "properties": {
        "started_at_us": { "$ref": "#/$defs/u64" },
        "ended_at_us": { "$ref": "#/$defs/u64" },
        "recorded_at_us": { "$ref": "#/$defs/u64" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at_us", "source", "content", "artifact_digest"],
      "properties": {
        "at_us": { "$ref": "#/$defs/u64" },
        "source": { "$ref": "#/$defs/text" },
        "content": { "$ref": "#/$defs/text" },
        "artifact_digest": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }] }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "confidence", "evidence"],
      "properties": {
        "content": { "$ref": "#/$defs/text" },
        "confidence": { "$ref": "#/$defs/ppm" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/digest" } }
      }
    },
    "belief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposition", "confidence", "evidence"],
      "properties": {
        "proposition": { "$ref": "#/$defs/text" },
        "confidence": { "$ref": "#/$defs/ppm" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/digest" } }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rationale"],
      "properties": {
        "decision": { "$ref": "#/$defs/text" },
        "rationale": { "$ref": "#/$defs/text" }
      }
    },
    "rejectedAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alternative", "reason"],
      "properties": {
        "alternative": { "$ref": "#/$defs/text" },
        "reason": { "$ref": "#/$defs/text" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "result"],
      "properties": {
        "action": { "$ref": "#/$defs/text" },
        "result": { "$ref": "#/$defs/nullableText" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "summary", "succeeded"],
      "properties": {
        "class": { "$ref": "#/$defs/text" },
        "summary": { "$ref": "#/$defs/text" },
        "succeeded": { "type": "boolean" }
      }
    },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "positive", "note"],
      "properties": {
        "source": { "$ref": "#/$defs/text" },
        "positive": { "type": "boolean" },
        "note": { "$ref": "#/$defs/nullableText" }
      }
    },
    "formationSignals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["utility", "salience", "novelty", "uncertainty"],
      "properties": {
        "utility": { "$ref": "#/$defs/ppm" },
        "salience": { "$ref": "#/$defs/ppm" },
        "novelty": { "$ref": "#/$defs/ppm" },
        "uncertainty": { "$ref": "#/$defs/ppm" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "source_event_digests", "policy_digest"],
      "properties": {
        "producer": { "$ref": "#/$defs/text" },
        "source_event_digests": { "type": "array", "items": { "$ref": "#/$defs/digest" } },
        "policy_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": { "enum": ["continues", "supports", "contradicts", "supersedes", "derived_from"] },
        "target": { "$ref": "#/$defs/digest" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "size_bytes", "media_type", "retention_allowed", "inline_payload"],
      "properties": {
        "digest": { "$ref": "#/$defs/digest" },
        "size_bytes": { "$ref": "#/$defs/u64" },
        "media_type": { "$ref": "#/$defs/text" },
        "retention_allowed": { "type": "boolean" },
        "inline_payload": {
          "oneOf": [
            { "type": "null" },
            { "type": "array", "maxItems": 4096, "items": { "type": "integer", "minimum": 0, "maximum": 255 } }
          ]
        }
      }
    },
    "consolidationScore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support", "diversity", "utility", "salience", "cohesion", "novelty", "uncertainty", "total"],
      "properties": {
        "support": { "$ref": "#/$defs/ppm" },
        "diversity": { "$ref": "#/$defs/ppm" },
        "utility": { "$ref": "#/$defs/ppm" },
        "salience": { "$ref": "#/$defs/ppm" },
        "cohesion": { "$ref": "#/$defs/ppm" },
        "novelty": { "$ref": "#/$defs/ppm" },
        "uncertainty": { "$ref": "#/$defs/ppm" },
        "total": { "$ref": "#/$defs/ppm" }
      }
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "episode" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["event_sequence_start", "event_sequence_end", "continues"],
              "properties": {
                "event_sequence_start": { "$ref": "#/$defs/u64" },
                "event_sequence_end": { "$ref": "#/$defs/u64" },
                "continues": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }] }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "semantic" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_ids", "source_body_digests", "score", "consensus_numerator", "consensus_denominator", "supersedes"],
              "properties": {
                "source_ids": { "type": "array", "minItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/digest" } },
                "source_body_digests": {
                  "type": "object",
                  "propertyNames": { "$ref": "#/$defs/digest" },
                  "additionalProperties": { "$ref": "#/$defs/digest" }
                },
                "score": { "$ref": "#/$defs/consolidationScore" },
                "consensus_numerator": { "$ref": "#/$defs/u32" },
                "consensus_denominator": { "$ref": "#/$defs/u32" },
                "supersedes": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }] }
              }
            }
          }
        }
      ]
    }
  }
}
